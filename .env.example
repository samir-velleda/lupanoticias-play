# .env.example (raiz) — SOMENTE NOMES DE CHAVE (sem valores sensíveis).
# Fonte de verdade em runtime: SSM Parameter Store `/lupa/<env>/*` + Secrets Manager.
# Nunca commitar valores reais. `.env*` (exceto este) está no .gitignore.

LUPA_ENV=dev
AWS_REGION=us-east-1
APP_URL=http://localhost:3000

# --- Data (Aurora) --- (secret real só no Secrets Manager /lupa/dev/aurora)
LUPA_AURORA_SECRET_ARN=            # SSM /lupa/dev/aurora/secret-arn
LUPA_AURORA_ENDPOINT=              # SSM /lupa/dev/aurora/endpoint
LUPA_AURORA_DB_NAME=lupa

# --- Storage / CDN ---
LUPA_MEDIA_BUCKET=                 # SSM /lupa/dev/storage/media-bucket
LUPA_UPLOADS_BUCKET=              # SSM /lupa/dev/storage/uploads-bucket
LUPA_WEB_STATIC_BUCKET=           # SSM /lupa/dev/storage/web-static-bucket
LUPA_CDN_DOMAIN=                  # SSM /lupa/dev/cdn/domain

# --- Auth (Cognito) ---
LUPA_COGNITO_USER_POOL_ID=        # SSM /lupa/dev/cognito/user-pool-id
LUPA_COGNITO_CLIENT_ID=           # SSM /lupa/dev/cognito/user-pool-client-id
LUPA_COGNITO_DOMAIN=              # SSM /lupa/dev/cognito/domain-base

# --- Web (deploy) ---
LUPA_WEB_URL=                     # SSM /lupa/dev/web/url (CloudFront de teste)
# LUPA_ORIGIN_SECRET é injetado pelo CloudFront/Secrets Manager no runtime do Lambda — nunca aqui.
